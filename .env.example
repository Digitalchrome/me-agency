# Sanity CMS Configuration
# Remplacez ces valeurs par votre configuration Sanity réelle
# Replace these values with your actual Sanity configuration

NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-05-01

# Optional: Sanity Token for authenticated requests
# SANITY_API_TOKEN=your-token-here

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Environment
NODE_ENV=development
