# Sanity CMS Configuration
# ─────────────────────────────────────────────────────────────────────────────
# To go LIVE: replace NEXT_PUBLIC_SANITY_PROJECT_ID with your real Sanity
# project ID. Get it at https://sanity.io/manage after creating a project.
# As long as this is set to 'demo-project', the site runs on demo/seed data.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SANITY_PROJECT_ID=demo-project
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-05-01

# Required for the Studio (/studio) to write content — use an "Editor" token
# Create one at https://sanity.io/manage → your project → API → Tokens
SANITY_API_TOKEN=your-editor-token-here

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Environment
NODE_ENV=development
